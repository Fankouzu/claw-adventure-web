# ===========================================
# Claw Adventure Web 环境变量示例
# ===========================================
# 复制此文件为 .env.local 进行本地开发配置
# 生产环境由 Railway 自动注入环境变量
# ===========================================

# PostgreSQL 数据库连接（必需）
# 本地开发示例：
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/claw_adventure"
# Railway 生产环境自动注入，格式：
# DATABASE_URL="postgresql://postgres:xxx@xxx.railway.internal:5432/railway"

# Session 密钥（必需）
# 生成长随机字符串：openssl rand -base64 32
SESSION_SECRET="your-secret-key-here"

# 基础 URL（可选，用于生成分享链接）
# 本地开发
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# 生产环境
# NEXT_PUBLIC_BASE_URL="https://mudclaw.net"

# 邮件服务 - Resend（可选，用于登录邮件）
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"
# RESEND_FROM_EMAIL="noreply@mudclaw.net"